---
// Calendario.astro
---

<section class="relative w-full py-5 px-4">
<div class="max-w-xs mx-auto relative z-10" id="wrapper-calendario">

        <!-- TÍTULO -->
        <div class="text-center mb-4 opacity-0" id="cal-titulo">
            <div class="flex items-center justify-center gap-3 mb-2">
                <div class="h-px w-10 bg-gradient-to-r from-transparent to-[#9a7a54]"></div>
                <img
                    src="/iconos/Anillos.png"
                    alt="anillos"
                    class="w-5 h-5 object-contain"
                    style="filter: brightness(0) saturate(100%) invert(56%) sepia(77%) saturate(419%) hue-rotate(5deg) brightness(94%) contrast(92%);"
                />
                <div class="h-px w-10 bg-gradient-to-l from-transparent to-[#9a7a54]"></div>
            </div>

        </div>

        <!-- CALENDARIO -->
        <div class="opacity-0" id="cal-grid">
            <div class="border-2 border-[#9a7a54] rounded-2xl overflow-hidden shadow-md">

                <!-- Cabecera mes -->
                <div class="bg-gradient-to-r from-[#939168] via-[#9a7a54] to-[#939168] py-2 px-3 flex items-center justify-center gap-3">
                    <div class="h-px flex-1 bg-white/30"></div>
                    <p class="font-charm text-white text-lg md:text-xl tracking-widest">
                        JUNIO · 2026
                    </p>
                    <div class="h-px flex-1 bg-white/30"></div>
                </div>

                <!-- Días de la semana -->
                <div class="grid grid-cols-7 bg-[#376b4c]/10">
                    {["Lun","Mar","Mié","Jue","Vie","Sáb","Dom"].map((d, i) => (
                        <div class={`py-1.5 text-center text-[10px] md:text-xs font-semibold tracking-wide ${i === 5 ? "text-[#9a7a54]" : "text-[#376b4c]/60"}`}>
                            {d}
                        </div>
                    ))}
                </div>

                <!-- Separador -->
                <div class="h-px bg-[#9a7a54]/20"></div>

                <!-- Días del mes -->
                <div class="grid grid-cols-7 bg-white/60">
                    <!-- Semana 1: 1–7 -->
                    {[1,2,3,4,5,6,7].map((d) => (
                        <div class={`
                            relative flex items-center justify-center py-2
                            ${d === 6 ? "text-[#9a7a54]" : ""}
                            ${d === 13 ? "z-10" : ""}
                        `}>
                            <span class={`
                                font-charm text-sm md:text-base
                                ${d === 6 ? "text-[#9a7a54] font-bold" : "text-[#376b4c]/70"}
                            `}>{d}</span>
                        </div>
                    ))}

                    <!-- Semana 2: 8–14 (13 = DÍA ESPECIAL) -->
                    {[8,9,10,11,12,13,14].map((d) => (
                        <div class={`
                            relative flex items-center justify-center py-2
                            ${d === 13 ? "z-10" : ""}
                        `}>
                            {d === 13 ? (
                                <div class="relative flex items-center justify-center">
                                    <!-- Aro exterior pulsante -->
                                    <div class="absolute w-8 h-8 md:w-9 md:h-9 rounded-full border-2 border-[#9a7a54]/40 animate-ping-cal"></div>
                                    <!-- Círculo dorado -->
                                    <div class="w-7 h-7 md:w-8 md:h-8 rounded-full bg-gradient-to-br from-[#939168] to-[#9a7a54] flex items-center justify-center shadow-lg shadow-[#9a7a54]/30">
                                        <span class="font-charm text-white text-sm md:text-base font-bold">13</span>
                                    </div>
                                </div>
                            ) : (
                                <span class={`font-charm text-sm md:text-base ${d === 13 ? "" : d === 14 ? "text-[#376b4c]/40" : "text-[#376b4c]/70"}`}>
                                    {d}
                                </span>
                            )}
                        </div>
                    ))}

                    <!-- Semana 3: 15–21 -->
                    {[15,16,17,18,19,20,21].map((d) => (
                        <div class="relative flex items-center justify-center py-2">
                            <span class={`font-charm text-sm md:text-base ${d === 20 ? "text-[#9a7a54]" : "text-[#376b4c]/70"}`}>{d}</span>
                        </div>
                    ))}

                    <!-- Semana 4: 22–28 -->
                    {[22,23,24,25,26,27,28].map((d) => (
                        <div class="relative flex items-center justify-center py-2">
                            <span class={`font-charm text-sm md:text-base ${d === 27 ? "text-[#9a7a54]" : "text-[#376b4c]/70"}`}>{d}</span>
                        </div>
                    ))}

                    <!-- Semana 5: 29–30 + celdas vacías -->
                    {[29,30].map((d) => (
                        <div class="relative flex items-center justify-center py-2">
                            <span class="font-charm text-sm md:text-base text-[#376b4c]/70">{d}</span>
                        </div>
                    ))}
                    {[...Array(5)].map(() => (
                        <div class="py-2"></div>
                    ))}
                </div>
            </div>
        </div>

      

    </div>
</section>

<style>
    @keyframes ping-cal {
        0% { transform: scale(1); opacity: 0.6; }
        75%, 100% { transform: scale(1.5); opacity: 0; }
    }
    .animate-ping-cal {
        animation: ping-cal 2s cubic-bezier(0, 0, 0.2, 1) infinite;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const initCalendario = () => {
        // Estado inicial
        gsap.set("#cal-titulo", { opacity: 0, y: 20 });
        gsap.set("#cal-grid", { opacity: 0, y: 30, scale: 0.97 });
        gsap.set("#cal-fecha-texto", { opacity: 0, y: 15 });

        ScrollTrigger.create({
            trigger: "#wrapper-calendario",
            start: "top 80%",
            end: "top 20%",

            onEnter: () => {
                const tl = gsap.timeline();

                tl.to("#cal-titulo", {
                        opacity: 1, y: 0, duration: 1, ease: "power3.out",
                    }, 0.3)
                    .to("#cal-grid", {
                        opacity: 1, y: 0, scale: 1, duration: 1.2, ease: "power3.out",
                    }, 0.6)
                    .to("#cal-fecha-texto", {
                        opacity: 1, y: 0, duration: 1, ease: "power3.out",
                    }, 1.0);

            },

            onLeaveBack: () => {
                gsap.to(["#cal-titulo", "#cal-grid", "#cal-fecha-texto"], {
                    opacity: 0, duration: 0.5, ease: "power2.in",
                });
                gsap.to("#cal-grid", { y: 30, scale: 0.97, duration: 0.5, ease: "power2.in" });
                gsap.to("#cal-titulo", { y: 20, duration: 0.5, ease: "power2.in" });
                gsap.to("#cal-fecha-texto", { y: 15, duration: 0.5, ease: "power2.in" });
            },
        });
    };

    document.addEventListener("DOMContentLoaded", initCalendario);
    document.addEventListener("astro:page-load", initCalendario);
</script>
